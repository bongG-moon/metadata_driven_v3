  "product_terms": {
    "AUTO_PRODUCT": {
      "display_name": "AUTO향 제품",
      "aliases": [
        "AUTO향",
        "오토모티브향",
        "오토향"
      ],
      "condition_by_family": {
        "production": {
          "$and": [
            {
              "MCP_NO": {
                "$exists": true,
                "$ne": ""
              }
            },
            {
              "MCP_NO": {
                "$regex": "[IONPQV]$"
              }
            }
          ]
        },
        "wip": {
          "$and": [
            {
              "MCP_NO": {
                "$exists": true,
                "$ne": ""
              }
            },
            {
              "MCP_NO": {
                "$regex": "[IONPQV]$"
              }
            }
          ]
        },
        "target": {
          "$and": [
            {
              "MCP NO": {
                "$exists": true,
                "$ne": ""
              }
            },
            {
              "MCP NO": {
                "$regex": "[IONPQV]$"
              }
            }
          ]
        },
        "lot": {
          "$and": [
            {
              "PROD_GRP_ID": {
                "$exists": true,
                "$ne": ""
              }
            },
            {
              "PROD_GRP_ID": {
                "$regex": "[IONPQV]$"
              }
            }
          ]
        },
        "hold": {
          "$and": [
            {
              "MCP_SALE_CD": {
                "$exists": true,
                "$ne": ""
              }
            },
            {
              "MCP_SALE_CD": {
                "$regex": "[IONPQV]$"
              }
            }
          ]
        },
        "equipment": {
          "$and": [
            {
              "MCPSALENO": {
                "$exists": true,
                "$ne": ""
              }
            },
            {
              "MCPSALENO": {
                "$regex": "[IONPQV]$"
              }
            }
          ]
        },
        "capacity": {
          "$and": [
            {
              "MCP_SALE_CD": {
                "$exists": true,
                "$ne": ""
              }
            },
            {
              "MCP_SALE_CD": {
                "$regex": "[IONPQV]$"
              }
            }
          ]
        }
      }
    },
