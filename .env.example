# Copy this file to .env and fill in real values.
# Do not commit real secrets.

# Runtime
AGENT_ENV=local
AGENT_TIMEZONE=Asia/Seoul
AGENT_DEFAULT_DATE=20260612

# Langflow Desktop / Web API
# Use the base URL plus flow ids for normal local verification.
# Example full run URL:
#   http://127.0.0.1:7860/api/v1/run/<flow_id>
LANGFLOW_BASE_URL=http://127.0.0.1:7860
LANGFLOW_API_KEY=
LANGFLOW_INPUT_TYPE=chat
LANGFLOW_OUTPUT_TYPE=chat
LANGFLOW_TIMEOUT_SECONDS=180

# Main router flow used by the future web app entry point.
LANGFLOW_ROUTER_FLOW_ID=
LANGFLOW_ROUTER_API_URL=

# Query subflows. The router canvas and web client can use either *_FLOW_ID
# with LANGFLOW_BASE_URL, or the explicit *_API_URL value.
LANGFLOW_METADATA_QA_FLOW_ID=
LANGFLOW_METADATA_QA_API_URL=
LANGFLOW_DATA_ANALYSIS_FLOW_ID=
LANGFLOW_DATA_ANALYSIS_API_URL=
LANGFLOW_REPORT_GENERATION_FLOW_ID=
LANGFLOW_REPORT_GENERATION_API_URL=
LANGFLOW_OPERATIONS_DIAGNOSIS_FLOW_ID=
LANGFLOW_OPERATIONS_DIAGNOSIS_API_URL=

# Metadata authoring flows used by the web metadata management screens.
LANGFLOW_DOMAIN_AUTHORING_FLOW_ID=
LANGFLOW_DOMAIN_AUTHORING_API_URL=
LANGFLOW_TABLE_CATALOG_AUTHORING_FLOW_ID=
LANGFLOW_TABLE_CATALOG_AUTHORING_API_URL=
LANGFLOW_MAIN_FILTER_AUTHORING_FLOW_ID=
LANGFLOW_MAIN_FILTER_AUTHORING_API_URL=
# Backward-compatible alias accepted by web_app.langflow_client.
LANGFLOW_MAIN_FLOW_FILTER_AUTHORING_API_URL=

# LLM validation
# This project follows the previous rebuild folder:
# - use Google Gemini through langchain_google_genai.ChatGoogleGenerativeAI
# - keep provider-neutral names so Langflow and Python validation can share them
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL_NAME=
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=60

# Optional aliases for tools that expect Google's conventional variable names.
# Keep them empty unless your local tooling needs them.
GOOGLE_API_KEY=
GEMINI_API_KEY=

# MongoDB metadata/result store
MONGODB_URI=
MONGODB_DATABASE=metadata_driven_agent_v3
MONGODB_DOMAIN_COLLECTION=agent_v3_domain_items
MONGODB_TABLE_CATALOG_COLLECTION=agent_v3_table_catalog_items
MONGODB_MAIN_FLOW_FILTER_COLLECTION=agent_v3_main_flow_filters
MONGODB_RESULT_COLLECTION=agent_v3_result_store

# Source retrieval
# Keep RUN_LIVE_SOURCE_RETRIEVAL=false for local validation.
# The runtime will use deterministic dummy rows while preserving source_type
# boundaries for oracle, h_api, datalake, and goodocs.
RUN_LIVE_SOURCE_RETRIEVAL=false
ORACLE_CONFIG_JSON=
H_API_TOKEN=
LAKE_USER_ID=
LAKE_JWT_TK=
GOODOCS_USER_ID=
GOODOCS_TOKEN_SOURCE=
GOODOCS_TOKEN_KEY=
GOODOCS_MODULE_NAME=
SOURCE_FETCH_LIMIT=5000

# Validation switches
RUN_LLM_VALIDATION=false
RUN_MONGODB_VALIDATION=false
RUN_LANGFLOW_API_VALIDATION=false
VALIDATION_LIMIT=
